; ============================================
; 通用工具 / 提示
; ============================================

; Toast(msg, ms)
; - 只使用 ToolTip（鼠标附近小提示），不再使用系统 TrayTip。
; - 这样可以避免调试期间系统通知反复堆积、弹出过慢的问题。
; - ms 表示气泡停留时长（毫秒），到时自动关闭。
Toast(msg, ms := 1200) {
    ToolTip(msg)                        ; 显示鼠标附近的小气泡提示
    SetTimer(() => ToolTip(), -ms)      ; 到时自动清空 ToolTip，避免残留
}
